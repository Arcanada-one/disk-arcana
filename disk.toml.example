# Disk Arcana — sample config for self-hosted v1.0 (Phase 1 stub).
# Copy to `disk.toml` and edit. The real daemon (DISK-0006) reads this file.

[sync]
# Local vault root that should mirror the server.
vault_path    = "/home/user/Vault"
# Polling interval (seconds) for the periodic reconciliation pass.
interval_secs = 30

[server]
# Disk Arcana server endpoint (gRPC + REST). HTTPS required in production.
url     = "https://disk.example.com"
# Per-node API key issued by AuthService.RegisterNode (DISK-0004).
api_key = "REPLACE_ME"

[vault]
# Client-side E2EE (DISK-0015). When true, uploads encrypt before DeltaUpload.
# Requires DISK_VAULT_PASSPHRASE and DISK_VAULT_SALT (hex) in the environment.
e2ee_enabled = false

[filter]
# Skip files larger than this (megabytes). Omit to disable.
max_file_size_mb = 200

[ignore]
# glob patterns relative to vault_path; merged with built-in defaults
# (.git, .obsidian/.cache, target, node_modules, ...).
patterns = [
    "**/.DS_Store",
    "**/.tmp/**",
]

[transport]
# gRPC transport settings (Phase 3, DISK-0004).
#
# Maximum size of a single compressed gRPC message before decompression (bytes).
# Default: 4 MiB.  Must not exceed the decompression-bomb guard cap.
max_compressed_message_bytes = 4194304
# Maximum decompressed size of a single message (bytes). Default: 16 MiB.
max_decompressed_message_bytes = 16777216
# Maximum total decompressed bytes per streaming RPC (bytes). Default: 256 MiB.
max_stream_decompressed_bytes = 268435456
# zstd compression level for outbound chunks (1–22). Default: 3 (fast).
zstd_level = 3

[tls]
# TLS certificate/key for the gRPC server (Phase 3, DISK-0004).
#
# Set cert_pem_path + key_pem_path to use a pre-provisioned certificate
# (e.g., Let's Encrypt / Cloudflare Origin Cert).
# Omit both to use an ephemeral self-signed cert (development only).
#
# cert_pem_path = "/etc/disk-arcana/tls/cert.pem"
# key_pem_path  = "/etc/disk-arcana/tls/key.pem"
#
# Minimum TLS version is always 1.3 (non-configurable).

[conflict]
# fork-suffix | fork-prefix | server-wins | client-wins (DISK-0007)
strategy = "fork-suffix"

[archive]
# Keep deleted files for `tombstone.ttl_days` before purging.
enabled = true

[daemon]
# trace | debug | info | warn | error
log_level = "info"

[tombstone]
ttl_days = 30

[telemetry]
# Anonymous usage telemetry (off by default).
opt_in = false
