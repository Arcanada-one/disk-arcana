# /etc/disk-arcana/env — environment file for disk-arcana-server.service
# Copy to /etc/disk-arcana/env, fill in real values, chmod 640, chown root:disk-arcana.
# NEVER commit the actual /etc/disk-arcana/env — secrets live in Vault only.
#
# To provision from Vault:
#   vault read -field=value arcanada/shared/ssl/disk.arcanada.one/cert > /etc/disk-arcana/tls/cert.pem
#   vault read -field=value arcanada/shared/ssl/disk.arcanada.one/key  > /etc/disk-arcana/tls/key.pem
#   vault read -field=value arcanada/shared/ssl/disk.arcanada.one/ca   > /etc/disk-arcana/tls/ca.pem

# --- Required ---
# exposure: 0.0.0.0:9443 — gRPC; justified: mTLS (Tier-3 per network-exposure-baseline);
#   no unauthenticated traffic reaches service logic; expires: 2026-09-09.
DISK_BIND_ADDR=0.0.0.0:9443
DISK_DB_PATH=/var/lib/disk-arcana/disk.db
DISK_SYNC_ROOT=/var/lib/disk-arcana/sync
DISK_TLS_CERT_PATH=/etc/disk-arcana/tls/cert.pem
DISK_TLS_KEY_PATH=/etc/disk-arcana/tls/key.pem
DISK_TLS_CA_PATH=/etc/disk-arcana/tls/ca.pem
DISK_ACL_YAML_PATH=/etc/disk-arcana/disk-acl.yaml

# --- GPG signature (required in production) ---
DISK_ACL_SIG_PATH=/etc/disk-arcana/disk-acl.yaml.asc
DISK_ACL_GNUPGHOME=/etc/disk-arcana/gpg

# --- Health endpoint ---
# exposure: 0.0.0.0:9446 — health HTTP; justified: Cloudflare-proxied CNAME
#   (health.disk.arcanada.one); origin only reachable via CF proxy; expires: 2026-09-09.
DISK_HEALTH_BIND_ADDR=0.0.0.0:9446

# --- Optional ---
# OPS_BOT_URL=https://ops.arcanada.one/events
# OPS_BOT_KEY=<from vault arcanada/ops-bot/key>
# DISK_ADMIN_TOKEN=<strong random token for disk admin pending-token>
# RUST_LOG=info
