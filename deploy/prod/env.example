# /etc/disk-arcana/env — environment file for disk-arcana-server.service
# Copy to /etc/disk-arcana/env, fill in real values, chmod 640, chown root:disk-arcana.
# NEVER commit the actual /etc/disk-arcana/env — secrets live in Vault only.
#
# DISK-0057 (P5-S1): leaf certs are minted OFFLINE from the Disk-mesh CA (Approach A-a).
# The root CA key NEVER leaves the operator workstation (tmpfs mint, shred after use).
# Per-node leaf cert + mesh CA root (NOT the CA root key) are distributed to each node.
#
# To provision TLS material from Vault (after P5-R-S1 CA-mint operator step):
#   vault kv get -field=cert arcanada/shared/ssl/disk-mesh-ca/<node>-leaf > /etc/disk-arcana/tls/cert.pem
#   vault kv get -field=key  arcanada/shared/ssl/disk-mesh-ca/<node>-leaf > /etc/disk-arcana/tls/key.pem
#   vault kv get -field=cert arcanada/shared/ssl/disk-mesh-ca/root        > /etc/disk-arcana/tls/ca.pem
# Substitute <node> with the node hostname (e.g. arcana-dev, mac-operator).
# Vault path: arcanada/shared/ssl/disk-mesh-ca/{root,arcana-dev-leaf,mac-operator-leaf}
# See runbook: documentation/runbooks/disk-arcana-prod-sync.md § P5-R-S1
#
# GUARD: dev-only stub-CA and allow-unsigned flags must NOT be set in this file.
# The binary fails closed (panics at startup) when no signed ACL exists and neither
# dev flag is set — that is the desired prod posture. The lint gate enforces absence:
# crates/disk-client/lints/check_dev_flags_not_in_prod.sh (CI-gated, exit 1 on violation).

# --- Required ---
# exposure: 0.0.0.0:9443 — gRPC; justified: mTLS (Tier-3 per network-exposure-baseline);
#   no unauthenticated traffic reaches service logic; expires: 2026-09-09.
DISK_BIND_ADDR=0.0.0.0:9443
# DISK-0057 (P5-S2): Approach A-a (pre-provisioned leaves) does not use the
# enrollment endpoint in production — leaves are minted offline and placed by the
# operator (see P5-R-S1 in the runbook). Loopback-only: no unauthenticated
# traffic can reach :9445 from outside the host. Reclassified as Tier-1 in
# docs/network-exposure.md (was Tier-3 public). expires: n/a (loopback).
# Note: if a third node is added in future, re-evaluate Approach A-c (OfflineCaClient)
# and restore the public bind with rate-limiting (tracked: DISK-0058).
DISK_ENROLLMENT_BIND_ADDR=127.0.0.1:9445
DISK_DB_PATH=/var/lib/disk-arcana/disk.db
DISK_SYNC_ROOT=/var/lib/disk-arcana/sync
DISK_TLS_CERT_PATH=/etc/disk-arcana/tls/cert.pem
DISK_TLS_KEY_PATH=/etc/disk-arcana/tls/key.pem
DISK_TLS_CA_PATH=/etc/disk-arcana/tls/ca.pem
DISK_ACL_YAML_PATH=/etc/disk-arcana/disk-acl.yaml

# --- GPG signature (required in production) ---
DISK_ACL_SIG_PATH=/etc/disk-arcana/disk-acl.yaml.asc
DISK_ACL_GNUPGHOME=/etc/disk-arcana/gpg

# --- Health endpoint ---
# exposure: 0.0.0.0:9446 — health HTTP; justified: Cloudflare-proxied CNAME
#   (health.disk.arcanada.ai); origin only reachable via CF proxy; expires: 2026-09-09.
DISK_HEALTH_BIND_ADDR=0.0.0.0:9446

# --- Optional ---
# OPS_BOT_URL=https://ops.arcanada.one/events
# OPS_BOT_KEY=<from vault arcanada/ops-bot/key>
# DISK_ADMIN_TOKEN=<strong random token for disk admin pending-token>
# RUST_LOG=info
