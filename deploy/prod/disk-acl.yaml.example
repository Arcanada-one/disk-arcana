# /etc/disk-arcana/disk-acl.yaml — Disk Arcana ACL policy.
# Sign with: gpg --homedir /etc/disk-arcana/gpg --batch --detach-sign --armor \
#   --default-key <SIGNING_KEY_ID> -o /etc/disk-arcana/disk-acl.yaml.asc \
#   /etc/disk-arcana/disk-acl.yaml
# See runbook: documentation/runbooks/disk-arcana/DISK-RB-007-acl-signing.md
version: 1

nodes:
  # Format: { cert_fingerprint: "<blake3-hex of DER-encoded leaf cert>", shares: { <share>: <role> } }
  # The ACL enforcer hashes the mTLS peer cert DER bytes with blake3, NOT sha256.
  # Compute: openssl x509 -in <leaf>.crt -outform DER | b3sum --no-names
  # (Install b3sum: brew install b3sum / cargo install b3sum)
  # See: crates/disk-server/src/auth/cert_identity.rs and scripts/dev-local-e2e.sh:151-168
  # Roles: bidirectional | receive_only | send_only | publisher
  #
  # Example — operator Mac node:
  # - cert_fingerprint: "aabbcc..."
  #   shares:
  #     kb-push-share: send_only
  #     sync-to-dev-share: send_only
  #     hermes-artefacts: receive_only
