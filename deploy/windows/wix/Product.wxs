<?xml version="1.0" encoding="UTF-8"?>
<!--
  Disk Arcana client — WiX scaffold (DISK-0013 Phase 5).

  NOT built in CI. Requires WiX Toolset on a Windows host.
  UpgradeCode must remain stable across releases once MSI ships.
  Replace Product/@Version and DiskComponent/File Source before release build.

  Build: scripts/build-msi.ps1 (Windows only)
-->
<Wix xmlns="http://schemas.microsoft.com/wix/2006/wi">
  <Product
    Id="*"
    Name="Disk Arcana Client"
    Language="1033"
    Version="0.1.0.0"
    Manufacturer="Arcanada"
    UpgradeCode="A7B3C4D5-E6F7-4890-ABCD-EF1234567890">

    <Package
      InstallerVersion="500"
      Compressed="yes"
      InstallScope="perMachine"
      Description="Disk Arcana file sync client"
      Comments="https://github.com/Arcanada-one/disk-arcana" />

    <MajorUpgrade
      DowngradeErrorMessage="A newer version of Disk Arcana is already installed." />

    <MediaTemplate EmbedCab="yes" />

    <Feature Id="MainFeature" Title="Disk Arcana Client" Level="1">
      <ComponentGroupRef Id="DiskArcanaComponents" />
    </Feature>

    <CustomAction Id="InstallService"
      Directory="INSTALLFOLDER"
      ExeCommand="[SystemFolder]sc.exe create DiskArcana binPath= &quot;[INSTALLFOLDER]disk.exe daemon start --foreground --config [CommonAppDataFolder]disk-arcana\disk.toml --state-dir [CommonAppDataFolder]disk-arcana\state&quot; start= auto DisplayName= &quot;Disk Arcana Client&quot;"
      Execute="deferred"
      Impersonate="no"
      Return="ignore" />

    <InstallExecuteSequence>
      <Custom Action="InstallService" After="InstallFiles">NOT Installed</Custom>
    </InstallExecuteSequence>
  </Product>

  <Fragment>
    <Directory Id="TARGETDIR" Name="SourceDir">
      <Directory Id="ProgramFiles64Folder">
        <Directory Id="INSTALLFOLDER" Name="Disk Arcana" />
      </Directory>
      <Directory Id="CommonAppDataFolder">
        <Directory Id="DATAROOT" Name="disk-arcana">
          <Directory Id="STATEDIR" Name="state" />
        </Directory>
      </Directory>
    </Directory>
  </Fragment>

  <Fragment>
    <ComponentGroup Id="DiskArcanaComponents" Directory="INSTALLFOLDER">
      <Component Id="DiskBinary" Guid="B1C2D3E4-F5A6-4789-B012-3456789ABCDE">
        <!-- build-msi.ps1 copies disk.exe beside Product.wxs before candle -->
        <File Id="DiskExe" Name="disk.exe" Source="disk.exe" KeyPath="yes" />
      </Component>
    </ComponentGroup>
  </Fragment>
</Wix>
